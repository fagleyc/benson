whisper/
logs/

# Secrets — these live in /etc/benson/env, not the repo, but defense-in-depth
*.env
.env*
secrets/
*.pem
*.key

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*~

# Self-modification artifacts
proposals/*.log

# WiFi creds for the ReSpeaker flash — local only, never publish
scripts/ears/secrets.yaml
scripts/ears/secrets.yaml.stub
